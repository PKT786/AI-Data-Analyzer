# Copy this file to .streamlit/secrets.toml (local dev) or paste its
# contents into your Streamlit Community Cloud app's "Secrets" settings.
# Every section below is optional - each feature just no-ops until its
# keys are filled in, so local email/password signup & login already
# work with zero configuration.

[google]
# Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID
# Authorized redirect URI must exactly match redirect_uri below.
client_id     = "xxxx.apps.googleusercontent.com"
client_secret = "xxxx"
redirect_uri  = "https://your-app-url.streamlit.app"

[facebook]
# developers.facebook.com -> your app -> Facebook Login -> Settings
# Valid OAuth Redirect URI must exactly match redirect_uri below.
app_id        = "xxxx"
app_secret    = "xxxx"
redirect_uri  = "https://your-app-url.streamlit.app"

[smtp]
# Sends the admin notification email on every signup/login.
# Use a Gmail "App Password" (Google Account -> Security -> App passwords),
# not your normal Gmail password.
email         = "your-sending-address@gmail.com"
app_password  = "xxxx xxxx xxxx xxxx"
admin_email   = "punitkr.786@gmail.com"

[sms]
# Sends the admin notification SMS on every signup/login, via Twilio.
# Swap the implementation in auth.py's _send_admin_sms() if you use a
# different SMS provider.
provider      = "twilio"
account_sid   = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
auth_token    = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
from_number   = "+1xxxxxxxxxx"
admin_mobile  = "+919145480345"
